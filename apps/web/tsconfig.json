{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    "baseUrl": ".",
    "paths": {
      "@whiteboard/core": ["../../packages/core/src/index.ts"],
      "@whiteboard/importers": ["../../packages/importers/src/index.ts"],
      "@whiteboard/api-client": ["../../packages/api-client/src/index.ts"]
    }
  },
  "include": ["src", "../../packages/*/src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
